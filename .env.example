# 관리자 설정
ADMIN_PASSWORD=your-strong-password-here
ADMIN_JWT_SECRET=your-32-byte-random-secret-here

# Vercel KV (Vercel 대시보드 Storage 탭에서 자동 주입됨)
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-kv-token

# ntfy.sh 알림 (https://ntfy.sh 토픽명, 추측 불가능한 랜덤값 권장)
NTFY_TOPIC=mongil-admin-xxxxxxxx

# GitHub API (코드 제안 자동 승인용)
GITHUB_TOKEN=github_pat_xxxxxxxx
GITHUB_OWNER=your-github-username
GITHUB_REPO=mongil-coupon

# IP 해시 salt (프라이버시 보호)
IP_HASH_SALT=your-random-salt-here

# 제안 알림 임계값 (기본 3표)
SUGGESTION_THRESHOLD=3
